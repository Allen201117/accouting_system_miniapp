/* pages/qc/home/home.wxss */
.qc-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #722ED1, #531DAB);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.user-role {
  font-size: 28rpx;
  opacity: 0.85;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 34rpx;
  color: #666;
  position: relative;
}

.tab-active {
  color: #722ED1;
  font-weight: bold;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #722ED1;
  border-radius: 2rpx;
}

.log-card {
  padding: 24rpx;
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.log-employee {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
}

.log-body {
  margin-bottom: 16rpx;
}

.log-row {
  display: flex;
  padding: 8rpx 0;
  font-size: 32rpx;
}

.log-label {
  color: #999;
  width: 160rpx;
}

.log-footer {
  text-align: right;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}
