/* pages/qc/inspect/inspect.wxss */
.detail-grid {
  display: flex;
  flex-wrap: wrap;
}

.detail-item {
  width: 50%;
  padding: 16rpx 0;
}

.detail-item:nth-child(4) {
  width: 100%;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}

.detail-value {
  font-size: 34rpx;
  color: #333;
}

.qty-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 52rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 96rpx;
  min-height: 0;
}

.qty-btn::after {
  border: none;
}

.qty-btn-sub {
  background: #FFF1F0;
  color: #FF4D4F;
}

.qty-btn-add {
  background: #F6FFED;
  color: #52C41A;
}

.qty-input {
  flex: 1;
  height: 96rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 16rpx;
  text-align: center;
  font-size: 52rpx;
  font-weight: bold;
}

.inspect-preview {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 24rpx;
}

.preview-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 34rpx;
}
