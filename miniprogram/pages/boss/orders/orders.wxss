/* pages/boss/orders/orders.wxss */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.add-btn {
  font-size: 30rpx;
  padding: 14rpx 28rpx;
  border-radius: 8rpx;
  line-height: 1.5;
  min-height: 0;
}

.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 12rpx;
  padding: 0 24rpx;
  background: #fff;
  font-size: 34rpx;
}

.picker-arrow {
  font-size: 28rpx;
  color: #999;
}

.order-card {
  padding: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-name {
  font-size: 38rpx;
  font-weight: bold;
}

.order-body {
  margin-bottom: 16rpx;
}

.order-row {
  display: flex;
  padding: 8rpx 0;
  font-size: 32rpx;
}

.order-label {
  color: #999;
  width: 140rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.btn-sm {
  font-size: 30rpx;
  padding: 10rpx 28rpx;
  border-radius: 8rpx;
  border: none;
  min-height: 0;
  line-height: 1.8;
}

.btn-sm::after { border: none; }

.btn-complete {
  background: #E6F7FF;
  color: #1890FF;
}
