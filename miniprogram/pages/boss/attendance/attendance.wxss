/* pages/boss/attendance/attendance.wxss */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 34rpx;
  color: #666;
  position: relative;
}

.tab-active {
  color: #FA541C;
  font-weight: bold;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #FA541C;
  border-radius: 2rpx;
}

.date-picker {
  font-size: 32rpx;
  color: #1890FF;
  padding: 8rpx 16rpx;
  background: #E6F7FF;
  border-radius: 8rpx;
}

.att-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  gap: 16rpx;
}

.att-row:last-child {
  border-bottom: none;
}

.att-name {
  font-size: 34rpx;
  font-weight: bold;
  width: 140rpx;
}

.att-date {
  font-size: 30rpx;
  color: #999;
  width: 150rpx;
}

.att-times {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.att-hours {
  font-size: 32rpx;
  color: #1890FF;
  font-weight: bold;
}

.btn-xs {
  font-size: 26rpx;
  padding: 6rpx 20rpx;
  border-radius: 6rpx;
  border: none;
  min-height: 0;
  line-height: 1.8;
}

.btn-xs::after { border: none; }

.btn-supplement {
  background: #FFF7E6;
  color: #FA8C16;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #fff;
  width: 85%;
  border-radius: 20rpx;
  padding: 40rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  font-size: 34rpx;
}

.info-label {
  color: #999;
}

.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 12rpx;
  padding: 0 24rpx;
  background: #fff;
  font-size: 34rpx;
}

.picker-arrow {
  font-size: 28rpx;
  color: #999;
}
