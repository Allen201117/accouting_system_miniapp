<!--pages/boss/home/home.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="boss-header">
    <view class="header-left">
      <text class="header-title">管理后台</text>
      <text class="header-date">{{todayDate}}</text>
    </view>
    <view class="header-right-info">
      <text class="header-username">{{userInfo.name}}</text>
      <text class="logout-text" bindtap="onLogout">退出</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-row">
    <view class="stat-card-sm">
      <text class="stat-num">{{stats.totalEmployees}}</text>
      <text class="stat-desc">员工总数</text>
    </view>
    <view class="stat-card-sm">
      <text class="stat-num text-success">{{stats.todayAttendance}}</text>
      <text class="stat-desc">今日出勤</text>
    </view>
    <view class="stat-card-sm">
      <text class="stat-num text-primary">{{stats.activeOrders}}</text>
      <text class="stat-desc">进行中订单</text>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-card-sm" style="flex:1;">
      <text class="stat-num text-warning">{{stats.pendingQC}}</text>
      <text class="stat-desc">待质检</text>
    </view>
    <view class="stat-card-sm" style="flex:2;">
      <text class="stat-num text-danger">¥{{stats.monthSalary}}</text>
      <text class="stat-desc">本月薪资支出</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="card">
    <view class="section-title">功能菜单</view>
    <view class="menu-grid">
      <view class="menu-grid-item" bindtap="goTo" data-page="employees">
        <view class="menu-icon-box" style="background:#E6F7FF;">👥</view>
        <text class="menu-label">员工管理</text>
      </view>
      <view class="menu-grid-item" bindtap="goTo" data-page="orders">
        <view class="menu-icon-box" style="background:#FFF7E6;">📋</view>
        <text class="menu-label">订单管理</text>
      </view>
      <view class="menu-grid-item" bindtap="goTo" data-page="attendance">
        <view class="menu-icon-box" style="background:#F6FFED;">📅</view>
        <text class="menu-label">考勤管理</text>
      </view>
      <view class="menu-grid-item" bindtap="goTo" data-page="salary">
        <view class="menu-icon-box" style="background:#FFF1F0;">💰</view>
        <text class="menu-label">薪酬管理</text>
      </view>
      <view class="menu-grid-item" bindtap="goTo" data-page="leaderboard">
        <view class="menu-icon-box" style="background:#F9F0FF;">🏆</view>
        <text class="menu-label">排行榜</text>
      </view>
      <view class="menu-grid-item" bindtap="goTo" data-page="qrcode">
        <view class="menu-icon-box" style="background:#E6FFFB;">📱</view>
        <text class="menu-label">考勤码</text>
      </view>
      <view class="menu-grid-item" bindtap="goToQC">
        <view class="menu-icon-box" style="background:#F0F5FF;">🔍</view>
        <text class="menu-label">质检管理</text>
      </view>
      <view class="menu-grid-item" bindtap="goTo" data-page="export">
        <view class="menu-icon-box" style="background:#FCFFE6;">📊</view>
        <text class="menu-label">导出报表</text>
      </view>
      <view class="menu-grid-item" bindtap="goTo" data-page="data-center">
        <view class="menu-icon-box" style="background:#F0F5FF;">🗄️</view>
        <text class="menu-label">数据中心</text>
      </view>
      <view class="menu-grid-item" bindtap="goTo" data-page="settings">
        <view class="menu-icon-box" style="background:#F0F0F0;">⚙️</view>
        <text class="menu-label">系统设置</text>
      </view>
      <view class="menu-grid-item" bindtap="openChangePwd">
        <view class="menu-icon-box" style="background:#FFF7E6;">🔒</view>
        <text class="menu-label">修改密码</text>
      </view>
    </view>
  </view>

  <!-- 修改密码弹窗 -->
  <view wx:if="{{showChangePwd}}">
    <view class="modal-mask" bindtap="closeChangePwd"></view>
    <view class="modal-dialog">
      <view class="modal-title">修改密码</view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">旧密码</text>
          <view class="pwd-input-wrap">
            <input class="input-field" type="{{showOldPwd ? 'text' : 'password'}}" placeholder="请输入旧密码" value="{{changePwdData.oldPassword}}" bindinput="onOldPwdInput" />
            <text class="pwd-toggle" bindtap="toggleOldPwd">{{showOldPwd ? '隐藏' : '显示'}}</text>
          </view>
        </view>
        <view class="input-group">
          <text class="input-label">新密码</text>
          <view class="pwd-input-wrap">
            <input class="input-field" type="{{showNewPwd ? 'text' : 'password'}}" placeholder="至少8位，含字母和数字" value="{{changePwdData.newPassword}}" bindinput="onNewPwdInput" />
            <text class="pwd-toggle" bindtap="toggleNewPwd">{{showNewPwd ? '隐藏' : '显示'}}</text>
          </view>
        </view>
        <view class="input-group">
          <text class="input-label">确认新密码</text>
          <input class="input-field" type="password" placeholder="再次输入新密码" value="{{changePwdData.confirmPassword}}" bindinput="onConfirmPwdInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-default modal-btn" bindtap="closeChangePwd">取消</button>
        <button class="btn-primary modal-btn" bindtap="onSubmitChangePwd" disabled="{{changePwdLoading}}">
          {{changePwdLoading ? '提交中...' : '确认修改'}}
        </button>
      </view>
    </view>
  </view>
</view>
