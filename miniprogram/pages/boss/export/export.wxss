/* pages/boss/export/export.wxss */
.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 12rpx;
  padding: 0 24rpx;
  background: #fff;
  font-size: 34rpx;
}

.picker-arrow {
  font-size: 28rpx;
  color: #999;
}

.btn-success {
  background: #52c41a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 34rpx;
  height: 88rpx;
  line-height: 88rpx;
}

/* 表格样式 */
.table-card {
  padding: 20rpx;
}

.table-scroll {
  width: 100%;
}

.table {
  display: inline-flex;
  flex-direction: column;
  min-width: 100%;
}

.table-row {
  display: flex;
  flex-direction: row;
}

.table-row-alt {
  background: #FAFAFA;
}

.table-header-row {
  background: #1890FF;
}

.table-cell {
  min-width: 160rpx;
  max-width: 280rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid #E8E8E8;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  overflow: hidden;
}

.table-header-cell {
  color: #fff;
  font-weight: bold;
  font-size: 28rpx;
  border-color: rgba(255,255,255,0.3);
}

.cell-text {
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-input {
  width: 100%;
  font-size: 28rpx;
  border: none;
  background: #FFFBE6;
  padding: 4rpx;
  min-height: 40rpx;
}