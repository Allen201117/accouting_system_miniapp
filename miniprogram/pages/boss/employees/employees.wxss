/* pages/boss/employees/employees.wxss */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.add-btn {
  font-size: 30rpx;
  padding: 14rpx 28rpx;
  border-radius: 8rpx;
  line-height: 1.5;
  min-height: 0;
}

.emp-card {
  padding: 24rpx;
}

.emp-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.emp-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1890FF;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.emp-info {
  flex: 1;
}

.emp-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.emp-phone {
  display: block;
  margin-top: 4rpx;
}

.emp-body {
  padding: 8rpx 0;
}

.emp-role {
  font-size: 32rpx;
  color: #666;
}

.emp-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.btn-sm {
  font-size: 30rpx;
  padding: 10rpx 28rpx;
  border-radius: 8rpx;
  border: none;
  min-height: 0;
  line-height: 1.8;
}

.btn-sm::after { border: none; }

.btn-edit {
  background: #E6F7FF;
  color: #1890FF;
}

.btn-disable {
  background: #FFF1F0;
  color: #FF4D4F;
}

.btn-enable {
  background: #F6FFED;
  color: #52C41A;
}

.btn-reset {
  background: #FFF7E6;
  color: #FA8C16;
}
