/* pages/boss/qrcode/qrcode.wxss */
.qr-card {
  text-align: center;
}

.qr-image-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 20rpx auto;
}

.qr-image {
  width: 500rpx;
  height: 500rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E8E8E8;
}

.qr-placeholder {
  width: 500rpx;
  height: 500rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #D9D9D9;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
}

.qr-placeholder-text {
  font-size: 32rpx;
  color: #999;
}

.qr-info {
  text-align: left;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.tip-list {
  padding: 10rpx 0;
}

.tip-item {
  font-size: 32rpx;
  color: #666;
  padding: 10rpx 0;
  line-height: 1.6;
}

/* 体验版二维码提示 */
.qr-fallback-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}
.qr-fallback-text {
  font-size: 28rpx;
  color: #FA8C16;
  text-align: center;
}

.qr-scheme-text {
  color: #52C41A;
}