<!--pages/boss/salary/salary.wxml-->
<view class="container">
  <!-- 总薪资统计 -->
  <view class="stat-card" style="background:linear-gradient(135deg, #FA541C, #D4380D);">
    <text class="stat-label">{{currentMonth}} 薪资总支出</text>
    <text class="stat-value">¥{{totalSalary}}</text>
    <text class="stat-sub">已发 {{paidCount}}/{{employees.length}} 人</text>
  </view>

  <!-- 员工薪资列表 -->
  <view class="card">
    <view class="section-title">员工薪资明细</view>
    
    <view wx:if="{{employees.length === 0}}" class="empty-state">
      <text class="empty-text">暂无薪资数据</text>
    </view>

    <view wx:for="{{employees}}" wx:key="user_id" class="salary-item">
      <view class="salary-check" catchtap="onTogglePaid" data-id="{{item.user_id}}" data-name="{{item.user_name}}" data-idx="{{index}}">
        <view class="checkbox {{item.paid ? 'checkbox-checked' : ''}}">
          <text wx:if="{{item.paid}}" class="checkmark">✓</text>
        </view>
      </view>
      <view class="salary-content" bindtap="goDetail" data-id="{{item.user_id}}" data-name="{{item.user_name}}">
        <view class="salary-left">
          <view class="salary-name-row">
            <text class="salary-name">{{item.user_name}}</text>
            <text wx:if="{{item.paid}}" class="paid-tag">已发</text>
            <text wx:else class="unpaid-tag">未发</text>
          </view>
          <text class="text-sm text-gray">计件: ¥{{item.baseSalary}} | 奖惩: ¥{{item.adjustmentTotal}}</text>
        </view>
        <view class="salary-right">
          <text class="salary-amount">¥{{item.finalSalary}}</text>
          <text class="text-sm text-primary">详情 →</text>
        </view>
      </view>
    </view>
  </view>
</view>
