/* pages/boss/salary/salary.wxss */
.salary-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.salary-item:last-child {
  border-bottom: none;
}

.salary-check {
  padding: 10rpx 20rpx 10rpx 0;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  border: 3rpx solid #D9D9D9;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.checkbox-checked {
  background: #52C41A;
  border-color: #52C41A;
}

.checkmark {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.salary-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.salary-left {
  flex: 1;
}

.salary-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.salary-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.paid-tag {
  font-size: 26rpx;
  color: #52C41A;
  background: #F6FFED;
  border: 1rpx solid #B7EB8F;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.unpaid-tag {
  font-size: 26rpx;
  color: #FA8C16;
  background: #FFF7E6;
  border: 1rpx solid #FFD591;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.salary-right {
  text-align: right;
}

.salary-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #FA541C;
  display: block;
  margin-bottom: 6rpx;
}

.stat-sub {
  font-size: 30rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}
