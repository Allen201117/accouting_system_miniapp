/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1890FF 0%, #096DD9 40%, #F5F5F5 40%);
  padding: 0 40rpx;
}

.login-header {
  padding-top: 80rpx;
  padding-bottom: 50rpx;
  text-align: center;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.app-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.85);
}

.login-form {
  padding: 50rpx 40rpx;
  border-radius: 20rpx;
}

.password-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.password-input {
  flex: 1;
  padding-right: 100rpx;
}

.toggle-pwd {
  position: absolute;
  right: 24rpx;
  font-size: 30rpx;
  color: #1890FF;
  padding: 10rpx;
}

.login-btn {
  margin-top: 50rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 36rpx;
  border-radius: 48rpx;
}

.login-tip {
  margin-top: 30rpx;
}

/* 改密弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-dialog {
  width: 620rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  padding: 36rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.modal-desc {
  display: block;
}

.modal-body {
  padding: 24rpx 32rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 32rpx 32rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  font-size: 34rpx;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  min-height: 0;
}

.consent-link-row {
  display: flex;
  justify-content: space-between;
}

.consent-check {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
