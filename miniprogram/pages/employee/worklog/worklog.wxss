/* pages/employee/worklog/worklog.wxss */
.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 12rpx;
  padding: 0 24rpx;
  background: #fff;
  font-size: 34rpx;
}

.picker-arrow {
  font-size: 28rpx;
  color: #999;
}

.qty-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 48rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 88rpx;
  min-height: 0;
}

.qty-btn::after {
  border: none;
}

.qty-btn-sub {
  background: #FFF1F0;
  color: #FF4D4F;
}

.qty-btn-add {
  background: #F6FFED;
  color: #52C41A;
}

.qty-btn-fast {
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 34rpx;
  font-weight: bold;
  background: #E6F7FF;
  color: #1890FF;
  border: none;
  padding: 0 24rpx;
  line-height: 88rpx;
  min-height: 0;
}

.qty-btn-fast::after {
  border: none;
}

.qty-input {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid #D9D9D9;
  border-radius: 12rpx;
  text-align: center;
  font-size: 48rpx;
  font-weight: bold;
}

.preview-amount {
  padding: 20rpx;
  background: #FFFBE6;
  border-radius: 12rpx;
  font-size: 34rpx;
  margin-top: 20rpx;
}

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.log-item:last-child {
  border-bottom: none;
}

.log-info {
  flex: 1;
}

.log-process {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 4rpx;
}

.log-order {
  display: block;
}

.log-detail {
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.log-qty {
  font-size: 34rpx;
  font-weight: bold;
}

.log-amount {
  font-size: 34rpx;
  font-weight: bold;
}

.btn-edit-log {
  font-size: 26rpx;
  padding: 6rpx 20rpx;
  background: #E6F7FF;
  color: #1890FF;
  border: none;
  border-radius: 8rpx;
  min-height: 0;
  line-height: 1.8;
  margin-top: 6rpx;
}
.btn-edit-log::after { border: none; }

.log-edit-wrap {
  margin-top: 6rpx;
}

.edit-info {
  background: #FAFAFA;
  padding: 16rpx;
  border-radius: 8rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-dialog {
  background: #fff;
  width: 85%;
  border-radius: 16rpx;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}
.modal-body {
  margin-bottom: 30rpx;
}
.modal-footer {
  display: flex;
  gap: 20rpx;
}
.modal-btn {
  flex: 1;
  font-size: 34rpx;
}
