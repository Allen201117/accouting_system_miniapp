<!--pages/employee/home/home.wxml-->
<view class="container">
  <!-- 用户信息头 -->
  <view class="user-header">
    <view class="user-avatar">{{userInfo.name[0]}}</view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name}}</text>
      <text class="user-role">员工</text>
      <text class="user-join-date text-sm text-gray" wx:if="{{joinDateDisplay}}">入厂时间：{{joinDateDisplay}}</text>
    </view>
    <view class="header-date">
      <text class="date-text">{{todayDate}}</text>
      <text class="time-text">{{currentTime}}</text>
    </view>
  </view>

  <!-- 打卡区域 -->
  <view class="clock-section card">
    <view class="section-title">考勤打卡</view>
    
    <view wx:if="{{clockSource === 'scan'}}" class="scan-badge">
      <text class="tag tag-info">扫码入口</text>
    </view>

    <view class="clock-buttons">
      <!-- 上班打卡 -->
      <view class="clock-btn-wrap">
        <button 
          class="clock-btn {{clockedIn ? 'clock-btn-done' : 'clock-btn-in'}}"
          bindtap="onClockIn"
          disabled="{{clockedIn || loading}}"
        >
          <text class="clock-btn-text">{{clockedIn ? '工作中' : '上班打卡'}}</text>
          <text class="clock-btn-time" wx:if="{{clockInTime}}">{{clockInTime}}</text>
        </button>
      </view>

      <!-- 下班打卡 -->
      <view class="clock-btn-wrap">
        <button 
          class="clock-btn {{clockedIn ? 'clock-btn-out' : 'clock-btn-disabled'}}"
          bindtap="onClockOut"
          disabled="{{!clockedIn || loading}}"
        >
          <text class="clock-btn-text">下班打卡</text>
          <text class="clock-btn-time" wx:if="{{clockOutTime}}">{{clockOutTime}}</text>
        </button>
      </view>
    </view>

    <view wx:if="{{sessionCount > 0}}" class="session-info" style="text-align:center; margin-top:16rpx; font-size:26rpx; color:#666;">
      今日已打卡 {{sessionCount}} 次，累计工时 {{todayHours}}h
    </view>
  </view>

  <!-- 今日概况 -->
  <view class="stats-row">
    <view class="stat-item card">
      <text class="stat-value text-primary">¥{{todayEarnings}}</text>
      <text class="stat-label">今日预估工资</text>
    </view>
    <view class="stat-item card">
      <text class="stat-value text-success">{{monthHours}}h</text>
      <text class="stat-label">本月累计工时</text>
    </view>
  </view>

  <!-- 快捷菜单 -->
  <view class="card">
    <view class="section-title">快捷操作</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onScanQR">
        <view class="menu-icon bg-purple">📷</view>
        <text class="menu-text">扫码打卡</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToWorklog">
        <view class="menu-icon bg-blue">📝</view>
        <text class="menu-text">计件报工</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToProfile">
        <view class="menu-icon bg-green">👤</view>
        <text class="menu-text">我的工资</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="openChangePwd">
        <view class="menu-icon bg-orange">🔒</view>
        <text class="menu-text">修改密码</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onLogout">
        <view class="menu-icon bg-red">🚪</view>
        <text class="menu-text">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 修改密码弹窗 -->
  <view wx:if="{{showChangePwd}}">
    <view class="modal-mask" bindtap="closeChangePwd"></view>
    <view class="modal-dialog">
      <view class="modal-title">修改密码</view>
      <view class="modal-body">
        <view class="input-group">
          <text class="input-label">旧密码</text>
          <view class="pwd-input-wrap">
            <input class="input-field" type="{{showOldPwd ? 'text' : 'password'}}" placeholder="请输入旧密码" value="{{changePwdData.oldPassword}}" bindinput="onOldPwdInput" />
            <text class="pwd-toggle" bindtap="toggleOldPwd">{{showOldPwd ? '隐藏' : '显示'}}</text>
          </view>
        </view>
        <view class="input-group">
          <text class="input-label">新密码</text>
          <view class="pwd-input-wrap">
            <input class="input-field" type="{{showNewPwd ? 'text' : 'password'}}" placeholder="至少8位，含字母和数字" value="{{changePwdData.newPassword}}" bindinput="onNewPwdInput" />
            <text class="pwd-toggle" bindtap="toggleNewPwd">{{showNewPwd ? '隐藏' : '显示'}}</text>
          </view>
        </view>
        <view class="input-group">
          <text class="input-label">确认新密码</text>
          <input class="input-field" type="password" placeholder="再次输入新密码" value="{{changePwdData.confirmPassword}}" bindinput="onConfirmPwdInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-default modal-btn" bindtap="closeChangePwd">取消</button>
        <button class="btn-primary modal-btn" bindtap="onSubmitChangePwd" disabled="{{changePwdLoading}}">
          {{changePwdLoading ? '提交中...' : '确认修改'}}
        </button>
      </view>
    </view>
  </view>
</view>
